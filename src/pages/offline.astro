---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
---

<StandaloneLayout title="Offline - The Muslim Post">
    <style is:inline>
        .offline-container {
            max-width: 600px;
            margin: 4rem auto;
            padding: 2rem;
            text-align: center;
        }
        .offline-container h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #1c1e21;
        }
        .offline-container p {
            font-size: 1.1rem;
            color: #606770;
            margin-bottom: 2rem;
        }
        .offline-container .retry-btn {
            background-color: #0073e6;
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .offline-container .retry-btn:hover {
            background-color: #005bb5;
        }
        .offline-icon {
            font-size: 4rem;
            color: #9ca3af;
            margin-bottom: 1rem;
        }
    </style>

    <div class="offline-container">
        <div class="offline-icon"><i class="fas fa-wifi"></i></div>
        <h1>You're Offline</h1>
        <p>It looks like you've lost your internet connection. Please check your network settings and try again.</p>
        <button class="retry-btn" onclick="window.location.reload()">Retry</button>
    </div>
</StandaloneLayout>
