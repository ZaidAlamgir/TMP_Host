        }
        .article-card-excerpt {
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            color: #475569;
            line-height: 1.6;
            margin-bottom: 1.25rem;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
