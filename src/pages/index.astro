---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Fetch all news articles and sort them to find the absolute newest one
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
const latestPost = sortedNews[0];

// 2. Helper variables to format the latest post data for the template
let latestUrl = "#";
let latestCategory = "general";
let formattedDate = "";
let truncatedSubheadline = "";

if (latestPost) {
    latestCategory = (latestPost.data.tags && latestPost.data.tags.length > 0) ? latestPost.data.tags[0] : 'general';
    latestUrl = `/news/${latestCategory}/${latestPost.id}`;
    formattedDate = new Date(latestPost.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    
    // Simulates Jekyll's truncatewords filter
    const sub = latestPost.data.subheadline || "";
    const words = sub.split(" ");
    truncatedSubheadline = words.length > 35 ? words.slice(0, 35).join(" ") + "..." : sub;
}
---

<Layout title="Home" body_class="home-page">
    
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "The Muslim Post",
      "url": "https://www.tmpnews.com/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://www.tmpnews.com/search.html?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <style is:inline>
        /* Custom premium homepage styles */
        .home-page {
            background-color: #f8fafc !important;
        }
        .support-cta-banner {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            background-color: #0f172a !important; /* Sleek slate-900 */
            border-bottom: none !important;
            padding: 0.5rem 1.5rem !important;
            margin: 0 auto 1.5rem auto;
            max-width: fit-content;
            border-radius: 50px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        .support-cta-banner p {
            margin: 0 !important;
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem !important;
            color: #f1f5f9 !important;
            font-weight: 500;
        }
        .support-cta-button {
            background-color: #facc15 !important;
            color: #0f172a !important;
            padding: 0.25rem 0.75rem !important;
            border-radius: 20px !important;
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem !important;
            font-weight: 800 !important;
            text-decoration: none !important;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            white-space: nowrap;
            box-shadow: none !important;
            transition: opacity 0.2s;
        }
        .support-cta-button:hover {
            opacity: 0.9;
            color: #0f172a !important;
        }
        @media (max-width: 640px) {
            .support-cta-banner {
                flex-direction: column;
                padding: 0.75rem 1rem !important;
                gap: 0.5rem;
                border-radius: 0 !important;
                width: 100% !important;
                max-width: 100% !important;
                margin: 0 0 1.5rem 0 !important;
                box-sizing: border-box;
            }
            .support-cta-banner p {
                font-size: 0.75rem !important;
                line-height: 1.3;
                text-align: center;
            }
        }

        .top-story-section {
            max-width: 1200px;
            margin: 0 auto 3rem auto;
            padding: 0 1rem;
        }
        .top-story-card {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            text-decoration: none;
            color: inherit;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .top-story-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
        }
        .top-story-image-wrapper {
            position: relative;
            overflow: hidden;
            width: 100%;
            aspect-ratio: 16/9;
            background-color: #f1f5f9;
        }
        .top-story-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .top-story-card:hover .top-story-image-wrapper img {
            transform: scale(1.03);
        }
        .desktop-kicker {
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            font-weight: 800;
            color: #dc2626;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }
        .top-story-headline {
            font-family: 'Merriweather', serif;
            font-weight: 900;
            font-size: 1.5rem;
            color: #0f172a;
            margin-bottom: 0.75rem;
            line-height: 1.3;
        }
        .top-story-subheadline {
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: #475569;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        .top-story-meta {
            display: flex;
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            color: #64748b;
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid #f1f5f9;
            align-items: center;
            justify-content: space-between;
        }
        .top-story-text {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            flex-grow: 1;
        }
        @media (min-width: 1024px) {
            .top-story-card {
                flex-direction: row;
                min-height: 460px;
                height: auto;
                align-items: stretch !important;
            }
            .top-story-image-wrapper {
                width: 60%;
                height: 100%;
                aspect-ratio: auto;
            }
            .top-story-text {
                width: 40%;
                padding: 2.5rem;
            }
            .top-story-headline {
                font-size: 2.25rem;
            }
        }

        /* Coverage and Filters */
        .content-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }
        .section-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .section-title {
            font-family: 'Merriweather', serif;
            font-weight: 900;
            font-size: 2.25rem;
            color: #0f172a;
        }
        .section-subtitle {
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: #64748b;
            margin-top: 0.5rem;
        }
        
        .category-filter-container {
            margin: 1.5rem 0 2.5rem 0;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 1rem;
        }
        .category-filter-scroll {
            display: flex;
            gap: 0.75rem;
            overflow-x: auto;
            scrollbar-width: none;
            padding: 0.25rem 0.25rem;
            -webkit-overflow-scrolling: touch;
        }
        .category-filter-scroll::-webkit-scrollbar {
            display: none;
        }
        .filter-btn {
            background: #ffffff;
            color: #475569;
            border: 1px solid #e2e8f0;
            padding: 0.55rem 1.25rem;
            border-radius: 9999px;
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            white-space: nowrap;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }
        .filter-btn:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #cbd5e1;
        }
        .filter-btn.active {
            background: #2563eb;
            color: #ffffff;
            border-color: #2563eb;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
        }

        /* Articles Grid */
        .articles-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        @media (min-width: 640px) {
            .articles-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (min-width: 1024px) {
            .articles-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .article-card {
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            opacity: 0;
            transform: translateY(10px);
        }
        .article-card.fade-in {
            animation: smoothFade 0.4s ease-out forwards;
        }
        @keyframes smoothFade {
