            grid-template-columns: 1fr;
            gap: 2.5rem;
            margin-top: 3rem;
        }
        @media (min-width: 768px) {
            .features-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        .feature-item {
            text-align: center;
            padding: 1rem;
        }
        .feature-icon {
            width: 60px;
            height: 60px;
            background: #eff6ff;
            color: #2563eb;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem auto;
        }
        .feature-item h3 {
            font-family: 'Merriweather', serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.75rem;
        }
        .feature-item p {
            font-family: 'Inter', sans-serif;
            font-size: 0.925rem;
            color: #64748b;
            line-height: 1.6;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #ffffff;
            padding: 5rem 2rem;
            text-align: center;
            border-radius: 24px;
            margin: 4rem auto;
            max-width: 1200px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.15);
        }
        .cta-content h1 {
            font-family: 'Merriweather', serif;
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            letter-spacing: -0.02em;
        }
        .cta-content p {
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            color: #cbd5e1;
            max-width: 600px;
            margin: 0 auto 2.5rem auto;
            line-height: 1.7;
        }
        .cta-button {
            background: #2563eb;
            color: #ffffff !important;
            padding: 1rem 2.5rem;
            border-radius: 9999px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(37, 99, 235, 0.4);
            transition: all 0.2s ease;
            display: inline-block;
        }
        .cta-button:hover {
            background: #1d4ed8;
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
            transform: translateY(-2px);
        }
        .cta-button:active {
            transform: translateY(0);
        }
    </style>

    <div class="support-cta-banner">
        <p>Independent journalism is more important than ever. Please consider supporting The Muslim Post today.</p>
        <a href="/support/" class="support-cta-button">Support TMP</a>
    </div>

    <main class="home-main" style="flex-grow: 1;">
        
        {latestPost && (
        <section class="top-story-section">
            <a href={latestUrl} class="top-story-card">
                <div class="top-story-image-wrapper">
                    <img src={latestPost.data.image || 'https://placehold.co/1200x800/e2e8f0/64748b?text=Image+Not+Available'} alt={latestPost.data.image_description || 'Top story image'} />
                </div>
                <div class="top-story-text">
                    <div>
                        <p class="desktop-kicker">Latest Report</p>
                        <h1 class="top-story-headline">{latestPost.data.title}</h1>
                        <p class="top-story-subheadline">{truncatedSubheadline}</p>
                    </div>
                    <div class="top-story-meta">
                        <span class="top-story-author">By {latestPost.data.author || "TMP Staff"} &bull; {formattedDate}</span>
                        <span class="read-more" style="color:#2563eb;font-weight:800;text-transform:uppercase;font-size:0.85rem;">Read Article &#8594;</span>
                    </div>
                </div>
            </a>
        </section>
        )}

        <div class="content-container">
            <section class="latest-news-section">
                <div class="section-header">
                    <h2 class="section-title">Latest Coverage</h2>
                    <p class="section-subtitle">Discover real-time reporting and analysis from our global newsroom.</p>
                </div>
                
                <!-- Category Scroll Bar -->
                <div class="category-filter-container">
                    <div class="category-filter-scroll" id="category-filter-bar">
                        <button class="filter-btn active" data-tag="all">All Latest</button>
                        <button class="filter-btn" data-tag="world-politics">World Politics</button>
                        <button class="filter-btn" data-tag="indian-politics">Indian Politics</button>
                        <button class="filter-btn" data-tag="muslim-world">Muslim World</button>
                        <button class="filter-btn" data-tag="technology">Technology</button>
                        <button class="filter-btn" data-tag="global-economy">Global Economy</button>
                        <button class="filter-btn" data-tag="middle-east">Middle East</button>
                        <button class="filter-btn" data-tag="climate">Climate</button>
                        <button class="filter-btn" data-tag="defense">Defense</button>
                        <button class="filter-btn" data-tag="sports">Sports</button>
                        <button class="filter-btn" data-tag="art-culture">Art & Culture</button>
                    </div>
                </div>
                
                <div class="articles-grid" id="home-articles-grid">
                    <!-- Cards will be populated dynamically -->
                </div>
                
                <div id="home-loader" class="loader"></div>
                <div id="home-no-results" class="no-results-message"></div>
                
                <div id="home-load-more-container" class="load-more-container">
                    <button id="home-load-more-btn" class="load-more-btn">Load More News</button>
                </div>
            </section>

            <section class="features-section reveal-on-scroll">
                <h2 class="section-title" style="text-align:center;">Why Join Us?</h2>
                <p class="section-subtitle" style="text-align:center;">A platform designed for sharing knowledge and fostering discussion.</p>
                <div class="features-grid">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                        </div>
                        <h3>Share Your Voice</h3>
                        <p>Easily post your articles, research, and opinions for a global audience.</p>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        </div>
                        <h3>Engage with Peers</h3>
                        <p>Connect with a community of experts and enthusiasts in various fields.</p>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 2v6h6M21.5 22v-6h-6"/><path d="M22 11.5A10 10 0 0 0 3.5 12.5"/><path d="M2 12.5a10 10 0 0 0 18.5-1"/></svg>
                        </div>
                        <h3>Stay Updated</h3>
                        <p>Follow the latest trends and discussions with our curated news section.</p>
                    </div>
                </div>
            </section>
        </div>

        <section class="cta-section">
            <div class="cta-content reveal-on-scroll">
                <h1>Share Your Knowledge</h1>
                <p>Join a community of thinkers, learners, and experts. Discover insightful posts and contribute your own perspective.</p>
                <a id="cta-get-started" href="/post/" class="cta-button">Get Started</a>
            </div>
        </section>
    </main>

    <script is:inline define:vars={{ latestId: latestPost ? latestPost.id : '' }}>
    (function() {
        function initHomePage() {
            const grid = document.getElementById('home-articles-grid');
            if (!grid || grid._homePageInitialized) return;
            grid._homePageInitialized = true;

            const loader = document.getElementById('home-loader');
            const noResults = document.getElementById('home-no-results');
            const loadMoreContainer = document.getElementById('home-load-more-container');
            const loadMoreBtn = document.getElementById('home-load-more-btn');
            const filterBar = document.getElementById('category-filter-bar');
            
            const CACHE_KEY = 'tmp_news_hub_v4';
            const BATCH_SIZE = 6; 
            
            let allArticles = [];
            let currentFiltered = [];
            let currentRenderedCount = 0;
            let activeTag = 'all';

            function formatTag(tag) {
                if (tag === 'art-culture') return 'Art & Culture';
                return tag.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            }

            function buildArticleCardsHTML(articles, shouldAnimate) {
                return articles.map(post => {
                    const image = post.image || 'https://placehold.co/600x400/e2e8f0/64748b?text=No+Image';
                    const alt = post.image_description || 'Article image';
                    const category = post.tags ? post.tags.split(',')[0].trim() : 'general';
                    const displayTag = formatTag(category);
                    const animClass = shouldAnimate ? 'fade-in' : '';
                    
                    return `
                    <a href="${post.url}" class="article-card ${animClass}">
                        <div class="article-card-image-wrapper">
                            <span class="article-card-tag">${displayTag}</span>
                            <img src="${image}" alt="${alt}" class="article-card-image" loading="lazy">
                        </div>
                        <div class="article-card-content">
                            <h3 class="article-card-title">${post.title}</h3>
                            <p class="article-card-excerpt">${post.subheadline || 'Click to read full article...'}</p>
                            <div class="article-card-meta">
                                <span>By TMP Staff</span>
                                <span>${post.date}</span>
                            </div>
                        </div>
                    </a>`;
                }).join('');
            }

            function renderGrid(animate = false) {
                // 1. Exclude the top story (latestPost) to avoid duplicate listing
                let filtered = allArticles;
                if (latestId) {
                    filtered = allArticles.filter(post => !post.url.endsWith(latestId));
                }
                
                // 2. Filter by tag if selected
                if (activeTag !== 'all') {
                    filtered = filtered.filter(post => {
                        const postTags = post.tags ? post.tags.split(',').map(t => t.trim().toLowerCase()) : [];
                        return postTags.includes(activeTag.toLowerCase());
                    });
                }
                
                currentFiltered = filtered;
                
                if (currentFiltered.length === 0) {
                    grid.innerHTML = '';
                    noResults.textContent = activeTag !== 'all' ? `No articles found for "${formatTag(activeTag)}".` : "No articles found.";
                    noResults.style.display = 'block';
                    loadMoreContainer.style.display = 'none';
                    return;
                }
                
                noResults.style.display = 'none';
                currentRenderedCount = Math.min(BATCH_SIZE, currentFiltered.length);
                grid.innerHTML = buildArticleCardsHTML(currentFiltered.slice(0, currentRenderedCount), animate);
                
                if (loadMoreContainer) {
                    loadMoreContainer.style.display = currentFiltered.length > currentRenderedCount ? 'block' : 'none';
                }
            }

            // Setup Load More
            if (loadMoreBtn && !loadMoreBtn._listenerAttached) {
                loadMoreBtn.addEventListener('click', () => {
                    const nextCount = Math.min(currentRenderedCount + BATCH_SIZE, currentFiltered.length);
                    const newHTML = buildArticleCardsHTML(currentFiltered.slice(currentRenderedCount, nextCount), true);
                    grid.insertAdjacentHTML('beforeend', newHTML);
                    currentRenderedCount = nextCount;
                    if (currentRenderedCount >= currentFiltered.length) {
                        loadMoreContainer.style.display = 'none';
                    }
                });
                loadMoreBtn._listenerAttached = true;
            }

            // Setup Filter Pills Click Events
            if (filterBar && !filterBar._listenerAttached) {
                filterBar.addEventListener('click', (e) => {
                    const btn = e.target.closest('.filter-btn');
                    if (!btn) return;
                    
                    filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    activeTag = btn.getAttribute('data-tag');
                    renderGrid(true);
                });
                filterBar._listenerAttached = true;
            }

            // Load articles from cache first
            const cachedData = localStorage.getItem(CACHE_KEY);
            if (cachedData) {
                try {
                    allArticles = JSON.parse(cachedData);
                    renderGrid(false);
                } catch (e) {
                    localStorage.removeItem(CACHE_KEY);
                }
            } else {
                if (loader) loader.classList.add('visible');
            }

            // Fetch fresh articles from API
            setTimeout(async () => {
                try {
                    const response = await fetch('/search.json');
                    if (!response.ok) throw new Error('Network error');
                    
                    const freshArticles = await response.json();
                    allArticles = freshArticles;
                    localStorage.setItem(CACHE_KEY, JSON.stringify(freshArticles));
                    renderGrid(true);
                } catch (error) {
                    if (grid.childElementCount === 0) {
                        noResults.textContent = "Could not load coverage.";
                        noResults.style.display = 'block';
                    }
                } finally {
                    if (loader) loader.classList.remove('visible');
                }
            }, 50);

            // Re-apply "Get Started" cta link check
            const getStartedBtn = document.getElementById('cta-get-started');
            if (getStartedBtn) {
                const cachedUser = localStorage.getItem('cachedUser');
                if (!cachedUser) {
                    getStartedBtn.href = "/auth.html";
                }
            }
            
            // Re-apply reveal observer
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
            document.querySelectorAll('.reveal-on-scroll').forEach(element => {
                observer.observe(element);
            });
        }

        document.addEventListener('turbo:load', initHomePage);
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
            initHomePage();
        } else {
            document.addEventListener('DOMContentLoaded', initHomePage);
        }
    })();
    </script>
</Layout>