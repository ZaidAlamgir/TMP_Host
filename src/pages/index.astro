        }
        .article-card-content {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }
        .article-card-title {
            font-family: 'Merriweather', serif;
            font-weight: 900;
            font-size: 1.15rem;
            line-height: 1.4;
            color: #0f172a;
            margin-bottom: 0.75rem;
            display: -webkit-box;
