---
// src/pages/news/[...slug].astro
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  const pathMap = new Map();

  for (const entry of allNews) {
    const rawTags = entry.data.tags || [];
    const rawCategories = entry.data.categories || [];
    const combinedTags = [...new Set([...rawTags, ...rawCategories])].map(t => t.toLowerCase());
    const categoryFolder = combinedTags.length > 0 ? combinedTags[0].replace(/\s+/g, '-') : 'general';

    const parts = entry.id.split('/');
    const filename = parts.pop() || entry.id;
    const subfolders = parts.join('/');
    const cleanSlug = filename.replace(/^\d{4}-\d{2}-\d{2}-/, '');
    const cleanNestedSlug = subfolders ? `${subfolders}/${cleanSlug}` : cleanSlug;

    const canonicalUrl = `/news/${categoryFolder}/${cleanNestedSlug}/`;

    // 1. Map by raw entry.id (redirect to canonical)
    if (!pathMap.has(entry.id)) {
      pathMap.set(entry.id, { params: { slug: entry.id }, props: { canonicalUrl } });
    }

    // 2. Map by filename (redirect to canonical)
    if (!pathMap.has(filename)) {
      pathMap.set(filename, { params: { slug: filename }, props: { canonicalUrl } });
    }

    // 3. Map by clean slug (redirect to canonical)
    if (!pathMap.has(cleanSlug)) {
      pathMap.set(cleanSlug, { params: { slug: cleanSlug }, props: { canonicalUrl } });
    }

    // 4. Map by clean nested slug (redirect to canonical)
    if (!pathMap.has(cleanNestedSlug)) {
      pathMap.set(cleanNestedSlug, { params: { slug: cleanNestedSlug }, props: { canonicalUrl } });
    }
  }

  return Array.from(pathMap.values());
}

const { canonicalUrl } = Astro.props;
return Astro.redirect(canonicalUrl);
---
