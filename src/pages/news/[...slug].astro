---
// src/pages/news/[...slug].astro
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  const pathMap = new Map();

  for (const entry of allNews) {
    const parts = entry.id.split('/');
    const filename = parts.pop() || entry.id;
    const subfolders = parts.join('/');
    const cleanSlug = filename.replace(/^\d{4}-\d{2}-\d{2}-/, '');
    const cleanNestedSlug = subfolders ? `${subfolders}/${cleanSlug}` : cleanSlug;

    // 1. Map by raw entry.id (e.g. /news/2025/11/2025-11-20-french-nuclear-waste...)
    if (!pathMap.has(entry.id)) {
      pathMap.set(entry.id, { params: { slug: entry.id }, props: { entry } });
    }

    // 2. Map by filename
    if (!pathMap.has(filename)) {
      pathMap.set(filename, { params: { slug: filename }, props: { entry } });
    }

    // 3. Map by clean slug (e.g. /news/french-nuclear-waste...)
    if (!pathMap.has(cleanSlug)) {
      pathMap.set(cleanSlug, { params: { slug: cleanSlug }, props: { entry } });
    }

    // 4. Map by clean nested slug
    if (!pathMap.has(cleanNestedSlug)) {
      pathMap.set(cleanNestedSlug, { params: { slug: cleanNestedSlug }, props: { entry } });
    }
  }

  return Array.from(pathMap.values());
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Compute the canonical URL (standard category folder + clean nested slug)
const rawTags = entry.data.tags || [];
const rawCategories = entry.data.categories || [];
const combinedTags = [...new Set([...rawTags, ...rawCategories])].map(t => t.toLowerCase());
const categoryFolder = combinedTags.length > 0 ? combinedTags[0].replace(/\s+/g, '-') : 'general';

const parts = entry.id.split('/');
const filename = parts.pop() || entry.id;
const subfolders = parts.join('/');
const cleanSlug = filename.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const cleanNestedSlug = subfolders ? `${subfolders}/${cleanSlug}` : cleanSlug;

const canonicalUrl = `https://www.tmpnews.com/news/${categoryFolder}/${cleanNestedSlug}/`;
---

<PostLayout 
    title={entry.data.title}
    subheadline={entry.data.subheadline}
    date={entry.data.date}
    image={entry.data.image}
    image_description={entry.data.image_description}
    tags={entry.data.tags}
    author={entry.data.author}
    writer={entry.data.writer}
    canonicalUrl={canonicalUrl}
>
    <Content />
</PostLayout>
