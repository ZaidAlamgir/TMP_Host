---
// src/components/Instagram.astro
const { id, caption } = Astro.props;
---

<div class="embed-container">
    <blockquote 
      class="instagram-media" 
      data-instgrm-permalink={`https://www.instagram.com/p/${id}/`} 
      data-instgrm-version="14" 
      style="background:#FFF; border:0; border-radius:3px; margin: 1px; max-width:540px; min-width:326px; padding:0; width:99.375%; width:-webkit-calc(100% - 2px); width:calc(100% - 2px);">
    </blockquote>
    {caption && <div class="embed-caption">{caption}</div>}
</div>